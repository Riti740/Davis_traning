        "def palindrome(x):\n",
        "    s = str(x)\n",
        "    if s == s[::-1]:\n",
        "        print(\"Palindrome\")\n",
        "    else:\n",
        "        print(\"Not Palindrome\")\n",
        "\n",
        "val = input(\"Enter value: \")\n",
        "palindrome(val)"
