      "source": [
        "while True:\n",
        "    print(\"\\n1.Add 2.Subtract 3.Multiply 4.Divide 5.Exit\")\n",
        "    ch = int(input(\"Enter choice: \"))\n",
        "\n",
        "    if ch == 5:\n",
        "        break\n",
        "\n",
        "    a = float(input(\"Enter first number: \"))\n",
        "    b = float(input(\"Enter second number: \"))\n",
        "\n",
        "    if ch == 1:\n",
        "        print(\"Result:\", a + b)\n",
        "    elif ch == 2:\n",
        "        print(\"Result:\", a - b)\n",
        "    elif ch == 3:\n",
        "        print(\"Result:\", a * b)\n",
        "    elif ch == 4:\n",
        "        if b == 0:\n",
        "            print(\"Cannot divide by zero\")\n",
        "        else:\n",
        "            print(\"Result:\", a / b)\n",
        "    else:\n",
        "        print(\"Invalid choice\")"
