        "def table(n):\n",
        "    if n < 0:\n",
        "        print(\"Invalid number\")\n",
        "        return\n",
        "    for i in range(1, 11):\n",
        "        print(n, \"x\", i, \"=\", n*i)\n",
        "\n",
        "num = int(input(\"Enter number: \"))\n",
        "table(num)"
