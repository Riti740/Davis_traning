      "source": [
        "def is_prime(n):\n",
        "    if n <= 1:\n",
        "        return False\n",
        "    for i in range(2, n):\n",
        "        if n % i == 0:\n",
        "            return False\n",
        "    return True\n",
        "\n",
        "num = int(input(\"Enter number: \"))\n",
        "if is_prime(num):\n",
        "    print(\"Prime Number\")\n",
        "else:\n",
        "    print(\"Not Prime\")"
